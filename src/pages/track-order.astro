---
import BaseLayout from '../layouts/BaseLayout.astro';

const title = 'Track Your Order | Vibe Test Lab';
const description = 'Track your Vibe Test Lab order with real-time shipping updates. Enter your tracking number to see exactly where your package is.';
const canonicalUrl = 'https://vibetestlab.com/track-order/';
---

<BaseLayout title={title} description={description} canonical={canonicalUrl}>
<style>
  .track-page { max-width: 800px; margin: 0 auto; padding: 2rem 1.5rem 4rem; }
  .track-header { margin-bottom: 2.5rem; text-align: center; }
  .track-header h1 { margin-bottom: .5rem; font-family: var(--font-mono, monospace); font-weight: 800; font-size: clamp(1.6rem, 4vw, 2.4rem); color: var(--color-text, #1a1a2e); }
  .track-header p { max-width: 480px; margin: 0 auto; font-size: .9rem; line-height: 1.6; color: #666; }
  .section-label { display: inline-block; font-size: 0.65rem; font-family: var(--font-sans, sans-serif); font-weight: 700; text-transform: uppercase; letter-spacing: 0.14em; color: var(--color-primary, #0d9488); margin-bottom: 0.4rem; }

  .track-input-wrap {
    display: flex; gap: 0.5rem; max-width: 560px; margin: 0 auto 2rem;
  }
  .track-input-wrap input[type="text"] {
    flex: 1; padding: 0.75rem 1rem; font-size: 1rem; font-family: var(--font-mono, monospace);
    border: 1px solid #e5e7eb; border-radius: 0.5rem; outline: none;
    transition: border-color 0.2s;
  }
  .track-input-wrap input[type="text"]:focus {
    border-color: var(--color-primary, #0d9488);
    box-shadow: 0 0 0 3px rgba(13, 148, 136, 0.1);
  }
  .track-input-wrap .track-btn {
    padding: 0.75rem 1.5rem; font-size: 0.85rem; font-weight: 700; font-family: var(--font-sans, sans-serif);
    text-transform: uppercase; letter-spacing: 0.08em;
    background: var(--color-primary, #0d9488); color: #fff; border: none; border-radius: 0.5rem;
    cursor: pointer; transition: background 0.2s;
  }
  .track-input-wrap .track-btn:hover { background: #0f766e; }

  .track-embed-wrap {
    background: #fff;
    border: 1px solid #e5e7eb;
    border-radius: 0.75rem;
    overflow: hidden;
    min-height: 500px;
    padding: 1rem;
  }

  .track-info {
    display: flex; gap: 1.5rem; flex-wrap: wrap;
    justify-content: center; margin-top: 2rem;
  }
  .track-info-item {
    display: flex; align-items: center; gap: .5rem;
    font-size: .8rem; color: #888;
    font-family: var(--font-mono, monospace); text-transform: uppercase; letter-spacing: 0.06em;
  }
  .track-info-item .icon { font-size: 1rem; }
</style>

<div class="track-page">
  <div class="track-header">
    <span class="section-label">Order Support</span>
    <h1>Track Your Order</h1>
    <p>Enter your tracking number below to get live updates on your shipment.</p>
  </div>

  <div class="track-input-wrap">
    <input type="text" id="YQNum" maxlength="50" placeholder="Enter tracking number..." />
    <input type="button" class="track-btn" value="TRACK" onclick="doTrack()" />
  </div>

  <div class="track-embed-wrap">
    <div id="YQContainer"></div>
  </div>

  <div class="track-info">
    <div class="track-info-item">
      <span class="icon">📦</span>
      <span>2-day US shipping</span>
    </div>
    <div class="track-info-item">
      <span class="icon">📧</span>
      <span>Tracking number in your confirmation email</span>
    </div>
    <div class="track-info-item">
      <span class="icon">🔄</span>
      <span>Issues? Full refund, no questions asked</span>
    </div>
  </div>

  <div style="text-align:center; margin-top:2.5rem;">
    <p style="font-size:.85rem;">Don't have your tracking number yet? Check your order confirmation email or <a href="mailto:support@vibetestlab.com" style="color:var(--color-primary, #0d9488);">contact us</a>.</p>
  </div>
</div>

<script type="text/javascript" src="//www.17track.net/externalcall.js"></script>
<script type="text/javascript">
  function doTrack() {
    var num = document.getElementById("YQNum").value;
    if (num === "") {
      alert("Enter your tracking number.");
      return;
    }
    YQV5.trackSingle({
      YQ_ContainerId: "YQContainer",
      YQ_Height: 560,
      YQ_Fc: "0",
      YQ_Lang: "en",
      YQ_Num: num
    });
  }
</script>
</BaseLayout>
