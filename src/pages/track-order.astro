---
import BaseLayout from '../layouts/BaseLayout.astro';

const title = 'Track Your Order | Vibe Test Lab';
const description = 'Track your Vibe Test Lab order in real time. Enter your tracking number to get live shipping updates.';
const canonicalUrl = 'https://vibe-test-labs.pages.dev/track-order';
---

<BaseLayout title={title} description={description} canonical={canonicalUrl} noindex={false}>
  <style>
    .track-page { max-width: 800px; margin: 0 auto; }
    .track-header { margin-bottom: 2.5rem; text-align: center; }
    .track-header h1 { margin-bottom: .5rem; }
    .track-header p { max-width: 480px; margin: 0 auto; }

    .track-embed-wrap {
      background: var(--card);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      overflow: hidden;
      min-height: 500px;
    }

    .track-info {
      display: flex; gap: 1.5rem; flex-wrap: wrap;
      justify-content: center; margin-top: 2rem;
    }
    .track-info-item {
      display: flex; align-items: center; gap: .5rem;
      font-size: .8rem; color: var(--muted-foreground);
      font-family: var(--font-mono); text-transform: uppercase; letter-spacing: .08em;
    }
    .track-info-item span.icon { font-size: 1rem; }
  </style>

  <div class="track-page">
    <div class="track-header">
      <span class="section-label">Order Support</span>
      <h1>Track Your Order</h1>
      <p>Enter your tracking number below to get live updates on your shipment.</p>
    </div>

    <div class="track-embed-wrap">
      <iframe
        src="https://t.17track.net/en#nums="
        width="100%"
        height="600"
        frameborder="0"
        scrolling="auto"
        title="Order Tracking"
        style="display:block; border:none; width:100%; min-height:600px;"
        loading="lazy"
      ></iframe>
    </div>

    <div class="track-info">
      <div class="track-info-item">
        <span class="icon">[Shipping]</span>
        <span>2-day US shipping</span>
      </div>
      <div class="track-info-item">
        <span class="icon">[Package]</span>
        <span>Tracking number in your confirmation email</span>
      </div>
      <div class="track-info-item">
        <span class="icon">[Returns]</span>
        <span>Issues? Full refund, no questions asked</span>
      </div>
    </div>

    <div style="text-align:center; margin-top:2.5rem;">
      <p style="font-size:.85rem;">Don't have your tracking number? Check your order confirmation email.<br/>Still need help? See our <a href="/faq">FAQ</a> or contact us.</p>
    </div>
  </div>
</BaseLayout>
