---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { articles } from '../../data/articles';

export function getStaticPaths() {
  return articles.map(article => ({
    params: { slug: article.slug },
    props: { article }
  }));
}

const { article } = Astro.props;

function scoreClass(s: number) { return s >= 85 ? 'high' : s >= 70 ? 'mid' : 'low'; }
function badgeClass(b: string) {
  if (b === 'Worth It') return 'verdict-badge-worth-it';
  if (b === 'Hidden Gem') return 'verdict-badge-hidden-gem';
  return 'verdict-badge-overhyped';
}

const articleSchema = {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": article.question,
  "description": article.shortAnswer,
  "datePublished": article.date,
  "author": { "@type": "Organization", "name": "Vibe Test Lab" }
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": article.faq.map(f => ({
    "@type": "Question",
    "name": f.question,
    "acceptedAnswer": { "@type": "Answer", "text": f.answer }
  }))
};
---

<BaseLayout
  title={`${article.question} | Vibe Test Lab`}
  description={article.shortAnswer.slice(0, 155)}
  canonical={`https://vibe-test-labs.pages.dev/tests/${article.slug}`}
  schema={[articleSchema, faqSchema]}
>

<style>
  /* ── LLM-extractable tables ─────────────────────────────── */
  .llm-table-section {
    margin: 2rem 0;
  }
  .llm-table-section .section-label {
    display: block;
    font-size: .7rem;
    font-family: var(--font-sans);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: .1em;
    color: var(--primary);
    margin-bottom: .75rem;
  }
  .llm-table-section h2 {
    margin: 0 0 1rem;
    font-size: 1.15rem;
  }

  .decision-table,
  .problem-solution-table,
  .tradeoffs-table {
    width: 100%;
    border-collapse: collapse;
    font-size: .875rem;
    border: 1px solid var(--border);
    border-radius: var(--radius);
    overflow: hidden;
  }
  .decision-table thead,
  .problem-solution-table thead,
  .tradeoffs-table thead {
    background: var(--card);
  }
  .decision-table th,
  .problem-solution-table th,
  .tradeoffs-table th {
    padding: .6rem .9rem;
    text-align: left;
    font-family: var(--font-sans);
    font-size: .7rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: .08em;
    color: var(--muted-foreground);
    border-bottom: 1px solid var(--border);
  }
  .decision-table td,
  .problem-solution-table td,
  .tradeoffs-table td {
    padding: .7rem .9rem;
    border-bottom: 1px solid var(--border);
    vertical-align: top;
    line-height: 1.5;
    color: var(--foreground);
  }
  .decision-table tr:last-child td,
  .problem-solution-table tr:last-child td,
  .tradeoffs-table tr:last-child td {
    border-bottom: none;
  }
  .decision-table tr:nth-child(even),
  .problem-solution-table tr:nth-child(even),
  .tradeoffs-table tr:nth-child(even) {
    background: color-mix(in srgb, var(--card) 60%, transparent);
  }
  .decision-table td:nth-child(2) {
    font-family: var(--font-mono);
    font-weight: 700;
    color: var(--primary);
    white-space: nowrap;
  }
  .tradeoffs-table td:first-child {
    font-family: var(--font-mono);
    font-weight: 700;
    font-size: .8rem;
    color: var(--muted-foreground);
    white-space: nowrap;
    width: 130px;
  }
  .problem-solution-table td:first-child {
    font-weight: 600;
    width: 35%;
  }

  /* ── Mobile overrides ──────────────────────────────────── */
  @media (max-width: 640px) {
    .decision-table td:nth-child(2) {
      white-space: normal;
    }
    .tradeoffs-table td:first-child {
      white-space: normal;
      width: auto;
    }
    .problem-solution-table td:first-child {
      width: auto;
    }
  }
</style>

<a href="/tests" class="back-link">&larr; Back to Tests</a>

<!-- Meta -->
<div style="display:flex;align-items:center;gap:.75rem;margin-bottom:1rem;flex-wrap:wrap;">
  <span style="font-size:.7rem;font-family:var(--font-sans);font-weight:600;text-transform:uppercase;letter-spacing:.1em;color:var(--primary);">{article.category}</span>
  <span style="color:var(--border);">&middot;</span>
  <span style="font-size:.7rem;color:var(--muted-foreground);">{article.date}</span>
  <span style="color:var(--border);">&middot;</span>
  <span style="font-size:.7rem;color:var(--muted-foreground);">{article.readTime}</span>
</div>

<h1>{article.question}</h1>

<!-- Featured answer -->
<div class="answer-box">
  <span class="section-label" style="margin-bottom:.75rem;">Quick Answer</span>
  <p class="lead">{article.shortAnswer}</p>
</div>

<!-- Hero image -->
<img
  src={article.image}
  alt={article.question}
  style="width:100%;height:320px;object-fit:cover;border-radius:var(--radius);margin:1.5rem 0;"
  loading="eager"
/>

<!-- Intro -->
<p>{article.intro}</p>

<!-- ── §1  Quick Decision Table ───────────────────────────── -->
{article.decision_table && article.decision_table.length > 0 && (
  <div class="llm-table-section">
    <span class="section-label">Quick Decision Guide</span>
    <h2>Which Option Is Right for You?</h2>
    <table class="decision-table">
      <thead>
        <tr>
          <th>If you need…</th>
          <th>Best Option</th>
          <th>Why</th>
        </tr>
      </thead>
      <tbody>
        {article.decision_table.map(row => (
          <tr>
            <td>{row.need}</td>
            <td>{row.best}</td>
            <td>{row.why}</td>
          </tr>
        ))}
      </tbody>
    </table>
  </div>
)}

<!-- ── §2  Problem → Solution Table ──────────────────────── -->
{article.problem_solution && article.problem_solution.length > 0 && (
  <div class="llm-table-section">
    <span class="section-label">Problem → Solution</span>
    <h2>What We Were Trying to Solve</h2>
    <table class="problem-solution-table">
      <thead>
        <tr>
          <th>The Problem</th>
          <th>Our Finding</th>
        </tr>
      </thead>
      <tbody>
        {article.problem_solution.map(row => (
          <tr>
            <td>{row.problem}</td>
            <td>{row.solution}</td>
          </tr>
        ))}
      </tbody>
    </table>
  </div>
)}

<!-- ── §3  Sections ───────────────────────────────────────── -->
{article.sections.map(section => (
  <div>
    <h2>{section.heading}</h2>
    <p>{section.body}</p>
  </div>
))}

<div class="divider-gradient" style="margin:2.5rem 0;"></div>

<!-- ── §4  Products tested ────────────────────────────────── -->
<h2>Products We Tested</h2>
<div class="tested-products-grid">
  {article.products.map(p => (
    <a href={`/products/${p.slug}`} class="tested-product-card">
      <img src={p.image} alt={p.name} class="tested-product-img" loading="lazy" />
      <div class="tested-product-body">
        <div class="tested-product-name">{p.name}</div>
        <div class="tested-product-meta">
          <span class={`verdict-badge ${badgeClass(p.verdictBadge)}`}>{p.verdictBadge}</span>
          <span class="tested-product-price">{p.price}</span>
        </div>
        <div class="tested-product-verdict">{p.verdict}</div>
        <span class="tested-product-cta">Add to Cart</span>
      </div>
    </a>
  ))}
</div>

<!-- ── §5  Tradeoffs Table ────────────────────────────────── -->
{article.tradeoffs && article.tradeoffs.length > 0 && (
  <div class="llm-table-section" style="margin-top:2.5rem;">
    <span class="section-label">Tradeoffs</span>
    <h2>How to Choose Between Options</h2>
    <table class="tradeoffs-table">
      <thead>
        <tr>
          <th>The Tradeoff</th>
          <th>If you prioritize A…</th>
          <th>If you prioritize B…</th>
        </tr>
      </thead>
      <tbody>
        {article.tradeoffs.map(row => (
          <tr>
            <td>{row.tradeoff}</td>
            <td>{row.side_a}</td>
            <td>{row.side_b}</td>
          </tr>
        ))}
      </tbody>
    </table>
  </div>
)}

<div class="divider-gradient" style="margin:2.5rem 0;"></div>

<!-- ── §6  FAQ ────────────────────────────────────────────── -->
<h2>Frequently Asked Questions</h2>
<div class="faq">
  {article.faq.map(item => (
    <div class="faq-item">
      <h3>{item.question}</h3>
      <p>{item.answer}</p>
    </div>
  ))}
</div>

</BaseLayout>
