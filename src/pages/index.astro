---
import BaseLayout from '../layouts/BaseLayout.astro';
import { products, categories } from '../data/products';
import { articles } from '../data/articles';

const siteUrl  = 'https://vibe-test-labs.pages.dev';
const trendingArticles = articles.slice(0, 4);
const topRated = [...products].sort((a, b) => b.vibeScore - a.vibeScore).slice(0, 4);


// Page-specific schema — BaseLayout always provides Organization + WebSite + Author
const pageSchema = [
  {
    "@type": "WebPage",
    "@id": `${siteUrl}/#webpage`,
    "url": siteUrl,
    "name": "Vibe Test Lab — We Test Viral Products",
    "description": "Independent product testing. Real tests, honest reviews of viral and trending consumer products.",
    "isPartOf": { "@id": `${siteUrl}#website` },
    "publisher": { "@id": `${siteUrl}#organization` },
    "speakable": {
      "@type": "SpeakableSpecification",
      "cssSelector": [".hero-content", ".answer-summary"]
    }
  },
  {
    "@type": "ItemList",
    "@id": `${siteUrl}/#featured`,
    "name": "Top Rated Products — Vibe Test Lab",
    "description": "The highest-scoring products from our independent lab tests.",
    "url": `${siteUrl}/top-rated`,
    "numberOfItems": topRated.length,
    "itemListElement": topRated.map((p, i) => ({
      "@type": "ListItem",
      "position": i + 1,
      "name": p.name,
      "url": `${siteUrl}/products/${p.slug}`,
      "item": {
        "@type": "Product",
        "name": p.name,
        "url": `${siteUrl}/products/${p.slug}`,
        "image": p.image,
        "brand": { "@type": "Brand", "name": p.brand },
        "aggregateRating": {
          "@type": "AggregateRating",
          "ratingValue": p.vibeScore.toString(),
          "bestRating": "100",
          "worstRating": "0",
          "ratingCount": "1"
        }
      }
    }))
  }
];

function scoreClass(s: number) { return s >= 85 ? 'high' : s >= 70 ? 'mid' : 'low'; }
function slugify(n: string) { return n.toLowerCase().replace(/\s+/g,'-').replace(/[^a-z0-9-]/g,''); }

const catColors = ['cat-a','cat-b','cat-c','cat-a','cat-b','cat-c','cat-a','cat-b'];
---

<BaseLayout
  title="Vibe Test Lab — We Test Viral Products"
  description="Vibe Test Lab tests trending viral products so you don't waste your money. Real tests, real results, honest reviews."
  schema={pageSchema}
  fullWidth={true}
>

<!-- HERO -->
<section class="hero-section">
  <img
    src="/hero-lab.jpg"
    alt="Vibe Test Lab — product testing"
    class="hero-overlay-img"
    loading="eager"
  />
  <div class="hero-fade"></div>
  <div class="hero-content">
    <p class="hero-label">Vibe Test Lab — Product Testing Division</p>
    <h1 class="hero-h1">We Test Viral Products So You Don't Waste Your Money</h1>
    <p class="hero-sub">Real tests. Real results. Only the best products pass the vibe check.</p>
    <a href="#trending" class="cta-button">See What Passed the Test</a>
  </div>
</section>
<div class="divider-gradient"></div>

<!-- TRENDING TESTS -->
<section id="trending" class="page-section">
  <div class="section-header">
    <div>
      <span class="section-label">Lab Report 001</span>
      <h2 style="margin:0;font-size:clamp(1.3rem,3vw,1.8rem);">Trending Tests</h2>
    </div>
    <a href="/tests" class="section-see-all">See all tests &rarr;</a>
  </div>
  {trendingArticles.map(article => (
    <article class="product-list-card">
      <div class="product-list-inner">
        <div class="product-list-img-wrap">
          <img src={article.image} alt={article.question} class="product-list-img" loading="lazy" />
        </div>
        <div class="product-list-body">
          <div>
            <div class="product-list-meta">
              <span class="product-list-category">{article.category}</span>
              <span class="product-list-dot">&middot;</span>
              <span class="product-list-date">{article.date}</span>
              <span class="product-list-dot">&middot;</span>
              <span class="product-list-date">{article.readTime}</span>
            </div>
            <a href={`/tests/${article.slug}`} class="product-list-name">{article.question}</a>
            <p class="product-list-verdict">{article.shortAnswer}</p>
          </div>
          <div class="product-list-footer">
            <div class="product-list-scores">
              <span style="font-size:.7rem;font-family:var(--font-sans);font-weight:600;text-transform:uppercase;letter-spacing:.1em;color:var(--muted-foreground);">
                {article.products.length} product{article.products.length !== 1 ? 's' : ''} tested
              </span>
            </div>
            <a href={`/tests/${article.slug}`} class="product-list-cta">Read Test &rarr;</a>
          </div>
        </div>
      </div>
      <div class="divider-gradient" style="margin-top:2rem;"></div>
    </article>
  ))}


      <!-- GUIDE CARDS: Buying guides inserted into trending section -->
      <article class="product-list-card">
        <div class="product-list-inner">
          <div class="product-list-img-wrap">
            <img src="https://cdn.shopify.com/s/files/1/0958/6710/9671/files/deep-sleep-bundle-hero.jpg" alt="Best sleep products 2026" class="product-list-img" loading="lazy" />
          </div>
          <div class="product-list-body">
            <div>
              <div class="product-list-meta">
                <span class="product-list-category">SLEEP &amp; WELLNESS</span>
                <span class="product-list-dot">&middot;</span>
                <span class="product-list-date">2026-03-29</span>
                <span class="product-list-dot">&middot;</span>
                <span class="product-list-date">9 min read</span>
              </div>
              <a href="/tests/best-sleep-products/" class="product-list-name">The Best Sleep Products for People Who Can't Turn Their Brain Off (2026)</a>
              <p class="product-list-verdict">10 products tested. The Deep Sleep Bundle (85/100) wins outright — but the real move is stacking white noise machine + weighted eye mask + sleep spray for a system that outperforms any single product.</p>
            </div>
          </div>
          <div class="product-list-footer">
            <div class="product-list-scores"><span style="font-size:.7rem;font-family:var(--font-sans);font-weight:600;text-transform:uppercase;letter-spacing:.08em;color:var(--color-text-secondary)">10 products tested</span></div>
            <a href="/tests/best-sleep-products/" class="product-list-cta">Read Guide &rarr;</a>
          </div>
        </div>
        <div class="divider-gradient" style="margin-top:2rem;"></div>
      </article>
      <article class="product-list-card">
        <div class="product-list-inner">
          <div class="product-list-img-wrap">
            <img src="https://cdn.shopify.com/s/files/1/0958/6710/9671/files/3cc4e80d4485a01c9ba8959b5e3e.png" alt="Best stress relief products 2026" class="product-list-img" loading="lazy" />
          </div>
          <div class="product-list-body">
            <div>
              <div class="product-list-meta">
                <span class="product-list-category">STRESS &amp; WELLNESS</span>
                <span class="product-list-dot">&middot;</span>
                <span class="product-list-date">2026-03-29</span>
                <span class="product-list-dot">&middot;</span>
                <span class="product-list-date">7 min read</span>
              </div>
              <a href="/tests/best-stress-relief-gifts/" class="product-list-name">The Best Stress Relief Products for When You Need to Actually Decompress (2026)</a>
              <p class="product-list-verdict">6 products measured for real decompression effect. The Wireless LED Face Mask (79/100) is the fastest-acting. For $12.99, the Serene Sleep Spray is the easiest add to any routine.</p>
            </div>
          </div>
          <div class="product-list-footer">
            <div class="product-list-scores"><span style="font-size:.7rem;font-family:var(--font-sans);font-weight:600;text-transform:uppercase;letter-spacing:.08em;color:var(--color-text-secondary)">6 products tested</span></div>
            <a href="/tests/best-stress-relief-gifts/" class="product-list-cta">Read Guide &rarr;</a>
          </div>
        </div>
        <div class="divider-gradient" style="margin-top:2rem;"></div>
      </article>
      <article class="product-list-card">
        <div class="product-list-inner">
          <div class="product-list-img-wrap">
            <img src="https://cdn.shopify.com/s/files/1/0958/6710/9671/files/weighted-eye-mask-hero.jpg" alt="Best self-care gifts 2026" class="product-list-img" loading="lazy" />
          </div>
          <div class="product-list-body">
            <div>
              <div class="product-list-meta">
                <span class="product-list-category">SELF-CARE &amp; BEAUTY</span>
                <span class="product-list-dot">&middot;</span>
                <span class="product-list-date">2026-03-29</span>
                <span class="product-list-dot">&middot;</span>
                <span class="product-list-date">7 min read</span>
              </div>
              <a href="/tests/best-self-care-gifts/" class="product-list-name">The Best Self-Care Gifts That Actually Feel Luxurious (2026)</a>
              <p class="product-list-verdict">6 devices tested for actual results and daily usability. The Wireless LED Face Mask leads (79/100, $69.99). Best budget pick: Weighted Eye Mask at $15.99 with a 77/100 score.</p>
            </div>
          </div>
          <div class="product-list-footer">
            <div class="product-list-scores"><span style="font-size:.7rem;font-family:var(--font-sans);font-weight:600;text-transform:uppercase;letter-spacing:.08em;color:var(--color-text-secondary)">6 products tested</span></div>
            <a href="/tests/best-self-care-gifts/" class="product-list-cta">Read Guide &rarr;</a>
          </div>
        </div>
        <div class="divider-gradient" style="margin-top:2rem;"></div>
      </article>
      <article class="product-list-card">
        <div class="product-list-inner">
          <div class="product-list-img-wrap">
            <img src="https://cdn.shopify.com/s/files/1/0958/6710/9671/files/ec93d8bf4e7dbc4a13e4e89e6faa.jpg" alt="Best dorm room essentials 2026" class="product-list-img" loading="lazy" />
          </div>
          <div class="product-list-body">
            <div>
              <div class="product-list-meta">
                <span class="product-list-category">DORM &amp; LIVING</span>
                <span class="product-list-dot">&middot;</span>
                <span class="product-list-date">2026-03-29</span>
                <span class="product-list-dot">&middot;</span>
                <span class="product-list-date">7 min read</span>
              </div>
              <a href="/tests/best-dorm-room-essentials/" class="product-list-name">The Best Dorm Room Upgrades That Actually Change the Vibe (2026)</a>
              <p class="product-list-verdict">7 dorm products tested. The Galaxy Star Projector (87/100, $62.11) is the single best upgrade for any small room. Pair with the Sensory Bed Sheet for under $100 total impact.</p>
            </div>
          </div>
          <div class="product-list-footer">
            <div class="product-list-scores"><span style="font-size:.7rem;font-family:var(--font-sans);font-weight:600;text-transform:uppercase;letter-spacing:.08em;color:var(--color-text-secondary)">7 products tested</span></div>
            <a href="/tests/best-dorm-room-essentials/" class="product-list-cta">Read Guide &rarr;</a>
          </div>
        </div>
        <div class="divider-gradient" style="margin-top:2rem;"></div>
      </article>
      <article class="product-list-card">
        <div class="product-list-inner">
          <div class="product-list-img-wrap">
            <img src="https://cdn.shopify.com/s/files/1/0958/6710/9671/files/4f268f7748ab9a6ec26a5ae2e6df.jpg" alt="Best birthday gifts 2026" class="product-list-img" loading="lazy" />
          </div>
          <div class="product-list-body">
            <div>
              <div class="product-list-meta">
                <span class="product-list-category">GIFT GUIDES</span>
                <span class="product-list-dot">&middot;</span>
                <span class="product-list-date">2026-03-29</span>
                <span class="product-list-dot">&middot;</span>
                <span class="product-list-date">8 min read</span>
              </div>
              <a href="/tests/best-gifts-for-birthdays/" class="product-list-name">The Best Birthday Gifts for People Who Actually Have Everything (2026)</a>
              <p class="product-list-verdict">8 tested birthday picks, zero gift cards. The Galaxy Star Projector (87/100) works for all ages. New parent gift: Baby Fox Teether Set (77/100, $87.86). Budget win: Wine Glass at $24.99.</p>
            </div>
          </div>
          <div class="product-list-footer">
            <div class="product-list-scores"><span style="font-size:.7rem;font-family:var(--font-sans);font-weight:600;text-transform:uppercase;letter-spacing:.08em;color:var(--color-text-secondary)">8 products tested</span></div>
            <a href="/tests/best-gifts-for-birthdays/" class="product-list-cta">Read Guide &rarr;</a>
          </div>
        </div>
        <div class="divider-gradient" style="margin-top:2rem;"></div>
      </article>
</section>

<!-- TOP RATED -->
<section id="top-rated" class="page-section" style="padding-top:0;">
  <div class="divider-gradient" style="margin-bottom:5rem;"></div>
  <div class="section-header">
    <div>
      <span class="section-label">Certified Results</span>
      <h2 style="margin:0;font-size:clamp(1.3rem,3vw,1.8rem);">Top Rated Products</h2>
    </div>
    <a href="/top-rated" class="section-see-all">See all &rarr;</a>
  </div>
  {topRated.map(product => (
    <article class="product-list-card">
      <div class="product-list-inner">
        <div class="product-list-img-wrap">
          <img src={product.image} alt={product.name} class="product-list-img" loading="lazy" />
        </div>
        <div class="product-list-body">
          <div>
            <div class="product-list-meta">
              <span class="product-list-category">{product.category}</span>
              <span class="product-list-dot">&middot;</span>
              <span class="product-list-date">{product.date}</span>
            </div>
            <a href={`/products/${product.slug}`} class="product-list-name">{product.name}</a>
            <p class="product-list-verdict">{product.verdict}</p>
          </div>
          <div class="product-list-footer">
            <div class="product-list-scores">
              <div class="vibe-score-wrap">
                <span class="vibe-score-label">Vibe Score</span>
                <span class={`vibe-score sm ${scoreClass(product.vibeScore)}`}>{product.vibeScore}</span>
              </div>
              <span class="product-list-price">{product.price}</span>
            </div>
            <a href={`/products/${product.slug}`} class="product-list-cta">Read Review &rarr;</a>
          </div>
        </div>
      </div>
      <div class="divider-gradient" style="margin-top:2rem;"></div>
    </article>
  ))}
</section>

<!-- CATEGORIES -->
<section id="categories" class="page-section" style="padding-top:0;">
  <div class="divider-gradient" style="margin-bottom:5rem;"></div>
  <div style="margin-bottom:2.5rem;">
    <span class="section-label">Index</span>
    <h2 style="margin:.25rem 0 0;font-size:clamp(1.3rem,3vw,1.8rem);">Browse by Category</h2>
  </div>
  <div class="categories-grid">
    {categories.filter(c => c !== 'All').map((cat, i) => (
      <a href={`/category/${slugify(cat)}`} class={`category-tile ${catColors[i % catColors.length]}`}>
        {cat}
      </a>
    ))}
  </div>
</section>

<!-- BUYER GUIDES -->
<section id="guides" class="page-section" style="padding-top:0;">
  <div class="divider-gradient" style="margin-bottom:5rem;"></div>
  <div class="section-header">
    <div>
      <span class="section-label">Buyer Guides</span>
      <h2 style="margin:0;font-size:clamp(1.3rem,3vw,1.8rem);">TOFU &amp; MOFU Guides</h2>
    </div>
  </div>
  <p style="margin:0 0 2rem;color:var(--muted-foreground);max-width:640px;">
    Curated roundups and comparison guides — tested products grouped by use case, not just product pages.
  </p>
  <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(280px,1fr));gap:1.5rem;">
    <a href="/guides/best-birthday-gifts-2026" class="category-tile cat-a" style="text-decoration:none;padding:1.5rem;display:flex;flex-direction:column;gap:.5rem;">
      <span style="font-weight:700;font-size:1rem;">Best Birthday Gifts of 2026</span>
      <span style="font-size:.8rem;opacity:.7;">8 products tested &middot; Gift Guide</span>
    </a>
    <a href="/guides/best-self-care-gifts-2026" class="category-tile cat-b" style="text-decoration:none;padding:1.5rem;display:flex;flex-direction:column;gap:.5rem;">
      <span style="font-weight:700;font-size:1rem;">Best Self-Care Gifts of 2026</span>
      <span style="font-size:.8rem;opacity:.7;">7 products tested &middot; Gift Guide</span>
    </a>
    <a href="/guides/best-sleep-products-2026" class="category-tile cat-c" style="text-decoration:none;padding:1.5rem;display:flex;flex-direction:column;gap:.5rem;">
      <span style="font-weight:700;font-size:1rem;">Best Sleep Products of 2026</span>
      <span style="font-size:.8rem;opacity:.7;">10 products tested &middot; Lifestyle Guide</span>
    </a>
    <a href="/guides/best-dorm-room-essentials-2026" class="category-tile cat-a" style="text-decoration:none;padding:1.5rem;display:flex;flex-direction:column;gap:.5rem;">
      <span style="font-weight:700;font-size:1rem;">Best Dorm Room Essentials 2026</span>
      <span style="font-size:.8rem;opacity:.7;">7 products tested &middot; Lifestyle Guide</span>
    </a>
    <a href="/guides/best-stress-relief-products-2026" class="category-tile cat-b" style="text-decoration:none;padding:1.5rem;display:flex;flex-direction:column;gap:.5rem;">
      <span style="font-weight:700;font-size:1rem;">Best Stress Relief Products 2026</span>
      <span style="font-size:.8rem;opacity:.7;">6 products tested &middot; Lifestyle Guide</span>
    </a>
  </div>
</section>

<!-- NEWSLETTER -->
<section id="newsletter" class="page-section" style="padding-top:0;">
  <div class="divider-gradient" style="margin-bottom:5rem;"></div>
  <div style="max-width:520px;">
    <h2 style="margin:0 0 1rem;font-size:clamp(1.3rem,3vw,1.8rem);">Lab Dispatch</h2>
    <p style="margin:0 0 2rem;">Weekly test results delivered to your inbox. No spam, just verdicts.</p>
    <form class="newsletter-form" id="nl-form">
      <input type="email" class="newsletter-input" placeholder="your@email.com" required />
      <button type="submit" class="newsletter-btn">Subscribe</button>
    </form>
    <p id="nl-thanks" style="display:none;font-family:var(--font-mono);font-size:.8rem;text-transform:uppercase;letter-spacing:.1em;color:var(--primary);font-weight:700;">
      You are on the list. First dispatch incoming.
    </p>
  </div>
</section>

<script is:inline>
  const form = document.getElementById('nl-form');
  const thanks = document.getElementById('nl-thanks');
  if (form && thanks) {
    form.addEventListener('submit', (e) => {
      e.preventDefault();
      (form as HTMLElement).style.display = 'none';
      (thanks as HTMLElement).style.display = 'block';
    });
  }
</script>

</BaseLayout>
