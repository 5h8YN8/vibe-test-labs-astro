const products = [
  { slug: 'ems-scalp-massager', name: 'EMS Scalp Massager', price: '$61.76', score: 76, badge: 'Hidden Gem', why: `EMS microcurrent + vibration in one device. Genuinely relaxing and has a built-in serum tank for treatments.` },
