  .comp-table tr:last-child td { border-bottom: none; }
  .faq details { border: 1px solid var(--border); border-radius: var(--radius); margin-bottom: .75rem; overflow: hidden; }
  .faq summary { padding: 1rem 1.25rem; font-weight: 600; cursor: pointer; background: var(--card); font-size: .95rem; }
  .faq summary:hover { background: var(--muted); }
