<style>
  .guide-hero { text-align: center; padding: 2rem 0 1.5rem; }
  .guide-hero h1 { font-size: 2rem; line-height: 1.2; margin-bottom: 1rem; }
  .guide-hero p { font-size: 1.05rem; color: var(--muted-foreground); max-width: 640px; margin: 0 auto; }
  .quick-picks { display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 1rem; margin: 2rem 0; }
  .comp-table { width: 100%; border-collapse: collapse; font-size: .875rem; border: 1px solid var(--border); border-radius: var(--radius); overflow: hidden; margin: 2rem 0; }
  .comp-table thead { background: var(--card); }
  .comp-table th { padding: .6rem .9rem; text-align: left; font-family: var(--font-sans); font-size: .7rem; font-weight: 700; text-transform: uppercase; letter-spacing: .08em; color: var(--muted-foreground); border-bottom: 1px solid var(--border); }
  .comp-table td { padding: .7rem .9rem; border-bottom: 1px solid var(--border); vertical-align: top; line-height: 1.5; color: var(--foreground); }
  .comp-table tr:last-child td { border-bottom: none; }
  .faq details { border: 1px solid var(--border); border-radius: var(--radius); margin-bottom: .75rem; overflow: hidden; }
  .faq summary { padding: 1rem 1.25rem; font-weight: 600; cursor: pointer; background: var(--card); font-size: .95rem; }
  .faq summary:hover { background: var(--muted); }
  .faq details[open] summary { border-bottom: 1px solid var(--border); }
  .faq details p { padding: 1rem 1.25rem; margin: 0; font-size: .9rem; line-height: 1.7; }
  @media (max-width: 640px) { .guide-hero h1 { font-size: 1.5rem; } .quick-picks { grid-template-columns: 1fr; } }
</style>

