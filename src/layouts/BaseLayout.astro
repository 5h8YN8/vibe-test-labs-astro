  <!-- Lightbox overlay -->
  <div class="vtl-lightbox" id="vtl-lightbox" aria-hidden="true" role="dialog" aria-label="Image viewer">
    <button class="vtl-lightbox-close" aria-label="Close lightbox">&times;</button>
    <button class="vtl-lightbox-prev" aria-label="Previous image">&#8249;</button>
    <button class="vtl-lightbox-next" aria-label="Next image">&#8250;</button>
    <img src="" alt="" id="vtl-lightbox-img" />
    <div class="vtl-lightbox-counter" id="vtl-lightbox-counter"></div>
  </div>

  <script is:inline>
  (function() {
    /* ── Interactive Gallery + Lightbox ──────────────────── */
    var galleries = document.querySelectorAll('.product-gallery');
    var lightbox = document.getElementById('vtl-lightbox');
    var lbImg = document.getElementById('vtl-lightbox-img');
    var lbCounter = document.getElementById('vtl-lightbox-counter');
    var lbClose = lightbox ? lightbox.querySelector('.vtl-lightbox-close') : null;
    var lbPrev = lightbox ? lightbox.querySelector('.vtl-lightbox-prev') : null;
    var lbNext = lightbox ? lightbox.querySelector('.vtl-lightbox-next') : null;
    var currentImages = [];
    var currentIndex = 0;

    function openLightbox(images, index) {
      currentImages = images;
      currentIndex = index;
      updateLightbox();
      lightbox.classList.add('open');
      lightbox.setAttribute('aria-hidden', 'false');
      document.body.style.overflow = 'hidden';
    }

    function closeLightbox() {
      lightbox.classList.remove('open');
      lightbox.setAttribute('aria-hidden', 'true');
      document.body.style.overflow = '';
    }

    function updateLightbox() {
      if (!currentImages.length) return;
      lbImg.src = currentImages[currentIndex].src;
      lbImg.alt = currentImages[currentIndex].alt || '';
      lbCounter.textContent = (currentIndex + 1) + ' / ' + currentImages.length;
    }

    function lbNavigate(dir) {
      currentIndex = (currentIndex + dir + currentImages.length) % currentImages.length;
      updateLightbox();
    }

    if (lbClose) lbClose.addEventListener('click', closeLightbox);
    if (lbPrev) lbPrev.addEventListener('click', function() { lbNavigate(-1); });
    if (lbNext) lbNext.addEventListener('click', function() { lbNavigate(1); });
    if (lightbox) lightbox.addEventListener('click', function(e) {
      if (e.target === lightbox) closeLightbox();
    });

    document.addEventListener('keydown', function(e) {
      if (!lightbox || !lightbox.classList.contains('open')) return;
      if (e.key === 'Escape') closeLightbox();
      if (e.key === 'ArrowLeft') lbNavigate(-1);
      if (e.key === 'ArrowRight') lbNavigate(1);
    });

    galleries.forEach(function(gallery) {
      var hero = gallery.querySelector('.product-gallery-hero');
      var heroImg = hero ? hero.querySelector('img') : null;
      var thumbsContainer = gallery.querySelector('.product-gallery-thumbs');
      var thumbs = thumbsContainer ? Array.from(thumbsContainer.querySelectorAll('img')) : [];

      /* Collect all image sources (hero first, then thumbs) */
      var allImages = [];
      if (heroImg) allImages.push({ src: heroImg.src, alt: heroImg.alt });
      thumbs.forEach(function(t) { allImages.push({ src: t.src, alt: t.alt }); });

      /* Add nav arrows to hero */
      if (allImages.length > 1 && hero) {
        var nav = document.createElement('div');
        nav.className = 'product-gallery-nav';
        nav.innerHTML = '<button aria-label="Previous image">&#8249;</button><button aria-label="Next image">&#8250;</button>';
        hero.parentNode.style.position = 'relative';
        hero.parentNode.insertBefore(nav, hero.nextSibling);

        var heroIndex = 0;
        var navBtns = nav.querySelectorAll('button');
        navBtns[0].addEventListener('click', function(e) {
          e.stopPropagation();
          heroIndex = (heroIndex - 1 + allImages.length) % allImages.length;
          heroImg.removeAttribute('srcset');
          heroImg.src = allImages[heroIndex].src;
          heroImg.alt = allImages[heroIndex].alt || '';
          updateActiveThumb(thumbs, heroIndex);
        });
        navBtns[1].addEventListener('click', function(e) {
          e.stopPropagation();
          heroIndex = (heroIndex + 1) % allImages.length;
          heroImg.removeAttribute('srcset');
          heroImg.src = allImages[heroIndex].src;
          heroImg.alt = allImages[heroIndex].alt || '';
          updateActiveThumb(thumbs, heroIndex);
        });

        /* Touch swipe on collapsed hero */
        var swipeStartX = 0;
        var swipeStartY = 0;
        var swipeMoved = false;
        hero.addEventListener('touchstart', function(e) {
          swipeStartX = e.changedTouches[0].clientX;
          swipeStartY = e.changedTouches[0].clientY;
          swipeMoved = false;
        }, { passive: true });
        hero.addEventListener('touchmove', function(e) {
          swipeMoved = true;
        }, { passive: true });
        hero.addEventListener('touchend', function(e) {
          var dx = e.changedTouches[0].clientX - swipeStartX;
          var dy = e.changedTouches[0].clientY - swipeStartY;
          if (Math.abs(dx) > 40 && Math.abs(dx) > Math.abs(dy)) {
            e.preventDefault();
            heroIndex = (heroIndex + (dx < 0 ? 1 : -1) + allImages.length) % allImages.length;
            heroImg.removeAttribute('srcset');
            heroImg.src = allImages[heroIndex].src;
            heroImg.alt = allImages[heroIndex].alt || '';
            updateActiveThumb(thumbs, heroIndex);
          }
        });

        /* Click hero to open lightbox (only when not swiping) */
        hero.addEventListener('click', function() {
          if (!swipeMoved) openLightbox(allImages, heroIndex);
        });

        /* Thumb clicks swap hero */
        thumbs.forEach(function(thumb, i) {
          thumb.addEventListener('click', function() {
            heroIndex = i + 1; /* +1 because allImages[0] is hero */
            heroImg.removeAttribute('srcset');
            heroImg.src = allImages[heroIndex].src;
            heroImg.alt = allImages[heroIndex].alt || '';
            updateActiveThumb(thumbs, heroIndex);
          });
        });
      } else if (hero) {
        /* Single image — still open lightbox on click */
        hero.addEventListener('click', function() {
          openLightbox(allImages, 0);
        });
      }
    });

    function updateActiveThumb(thumbs, heroIndex) {
      thumbs.forEach(function(t, i) {
        /* heroIndex 0 = hero image (no thumb), heroIndex 1+ maps to thumb i */
        if (i === heroIndex - 1) {
          t.classList.add('active');
        } else {
          t.classList.remove('active');
        }
      });
    }
  })();
  </script>

  <!-- Cookie Consent Banner (GDPR + CCPA) -->
  <div id="vtl-cookie-banner" role="dialog" aria-label="Cookie consent" aria-modal="false" style="display:none;position:fixed;bottom:0;left:0;right:0;z-index:9999;background:#1a1a2e;border-top:1px solid rgba(255,255,255,0.12);padding:1rem 1.5rem;box-shadow:0 -4px 24px rgba(0,0,0,0.4);">
    <div style="max-width:1100px;margin:0 auto;display:flex;flex-wrap:wrap;align-items:center;gap:1rem;">
      <div style="flex:1;min-width:260px;">
        <p style="margin:0 0 0.25rem;font-size:0.9rem;line-height:1.5;color:#e0e0e0;">
          We use cookies to improve your experience and for analytics. By clicking <strong>Accept All</strong>, you consent to our use of cookies as described in our <a href="/privacy" style="color:#a78bfa;text-decoration:underline;">Privacy Policy</a>.
        </p>
        <p style="margin:0;font-size:0.75rem;color:#888;">
          We do not sell your personal information. <a href="/privacy" style="color:#888;text-decoration:underline;white-space:nowrap;">Do Not Sell or Share My Personal Information</a>
        </p>
      </div>
      <div style="display:flex;gap:0.625rem;flex-shrink:0;flex-wrap:wrap;align-items:center;">
        <button id="vtl-cookie-decline" style="padding:0.5rem 1.1rem;border-radius:0.5rem;border:1px solid rgba(255,255,255,0.2);background:transparent;color:#ccc;font-size:0.85rem;cursor:pointer;">
          Decline
        </button>
        <button id="vtl-cookie-accept" style="padding:0.5rem 1.25rem;border-radius:0.5rem;border:none;background:linear-gradient(135deg,#7c3aed,#4f46e5);color:#fff;font-size:0.85rem;font-weight:600;cursor:pointer;">
          Accept All
        </button>
      </div>
    </div>
  </div>
  <script is:inline>
    (function() {
      var KEY = 'vtl_cookie_consent';
      var banner = document.getElementById('vtl-cookie-banner');
      var acceptBtn = document.getElementById('vtl-cookie-accept');
      var declineBtn = document.getElementById('vtl-cookie-decline');
      if (!banner) return;
      try {
        if (!localStorage.getItem(KEY)) banner.style.display = 'block';
      } catch(e) { banner.style.display = 'block'; }
      function updateConsent(granted) {
        var val = granted ? 'granted' : 'denied';
        if (typeof window.gtag === 'function') {
          window.gtag('consent', 'update', {
            'ad_storage': val, 'ad_user_data': val,
            'ad_personalization': val, 'analytics_storage': val
          });
        }
        window.dataLayer = window.dataLayer || [];
        window.dataLayer.push({ event: granted ? 'cookie_consent_accepted' : 'cookie_consent_declined' });
      }
      function setConsent(choice) {
        try { localStorage.setItem(KEY, choice); } catch(e) {}
        banner.style.display = 'none';
        updateConsent(choice === 'accepted');
      }
      acceptBtn.addEventListener('click', function() { setConsent('accepted'); });
      declineBtn.addEventListener('click', function() { setConsent('declined'); });
      declineBtn.addEventListener('mouseenter', function() { this.style.background = 'rgba(255,255,255,0.08)'; });
      declineBtn.addEventListener('mouseleave', function() { this.style.background = 'transparent'; });
      acceptBtn.addEventListener('mouseenter', function() { this.style.opacity = '0.88'; });
      acceptBtn.addEventListener('mouseleave', function() { this.style.opacity = '1'; });
    })();
  </script>
  <!-- End Cookie Consent Banner -->
</body>
</html>
