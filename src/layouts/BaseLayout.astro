    <div class="site-nav-inner">
      <a href="/" class="site-nav-logo" aria-label="Vibe Test Lab">
        <img src="/logo.png" alt="Vibe Test Lab" class="nav-logo-img" />
      </a>
      <div class="site-nav-links">
        <a href="/tests" class="nav-hide-mobile">Tests</a>
        <a href="/top-rated" class="nav-hide-mobile">Top Rated</a>
        <a href="/products" class="nav-hide-mobile">Products</a>
        <a href="/#newsletter" class="nav-cta">Subscribe</a>
      </div>
    </div>
  </nav>

  <main class={fullWidth ? 'full-main' : 'content-main'}>
    <slot />
  </main>

